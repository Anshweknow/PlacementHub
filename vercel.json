{
  "version": 2,
  "builds": [
    {
      "src": "placement-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(auth|profile|job|application|hr|uploads)(/.*)?",
      "dest": "/api/index.js"
    },
    {
      "src": "/(assets/.*|favicon\\.ico|vite\\.svg|.*\\.(?:js|css|mjs|map|json|png|jpg|jpeg|gif|svg|ico|webp|avif|woff|woff2|ttf|eot))",
      "dest": "/placement-frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/placement-frontend/index.html"
    }
  ]
}
